  "@type": "CollegeOrUniversity",
  "@id": "https://www.uq.edu.au/",
  "name": "The University of Queensland",
  "url": "https://www.uq.edu.au/",
  "description": "Public research university in Brisbane, Australia. Its public API footprint centres on UQ eSpace, the institutional digital repository, which exposes an OAI-PMH metadata harvesting endpoint and a documented eSpace REST API.",
  "sameAs": [
    "https://github.com/uqlibrary",
    "https://au.linkedin.com/school/university-of-queensland/",
    "https://espace.library.uq.edu.au/"
  ],
  "location": {
    "@type": "Place",
    "name": "Brisbane, Queensland, Australia"
  },
  "subOrganization": {
    "@type": "Library",
    "name": "The University of Queensland Library",
    "url": "https://web.library.uq.edu.au/",
    "department": {
      "@type": "DigitalDocument",
      "name": "UQ eSpace",
      "description": "Institutional digital repository of UQ research publications, theses, and datasets, built on the Fez/Fedora platform.",
      "url": "https://espace.library.uq.edu.au/",
      "api": {
        "@type": "WebAPI",
        "name": "UQ eSpace OAI-PMH",
        "baseURL": "https://espace.library.uq.edu.au/oai.php",
        "metadataFormat": "oai_dc"
      }
    }
  }
